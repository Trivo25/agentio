# 0G Storage live test configuration.
# Copy this file to .env, fill in values, and never commit real private keys.

AGENTIO_0G_EVM_RPC=https://evmrpc-testnet.0g.ai
AGENTIO_0G_INDEXER_RPC=https://indexer-storage-testnet-turbo.0g.ai
# Required for live KV round-trip tests. 0G currently expects applications to
# run their own KV node; the public storage indexer does not expose one for us.
AGENTIO_0G_KV_RPC=

# Must be a funded EVM private key: 0x + 64 hex characters.
# Generate a test-only wallet with: npm run keys:evm
AGENTIO_0G_PRIVATE_KEY=0x...

# Must be a 32-byte 0G KV stream id: 0x + 64 hex characters.
# Generate one with: npm run keys:stream
AGENTIO_0G_STREAM_ID=0x...

# Optional prefix used by live tests so keys do not collide with other app data.
AGENTIO_0G_NAMESPACE=agentio-live

# Optional timeout for storage-node log sync in live smoke tests.
# Increase this if the testnet accepts the transaction but the selected node is slow to observe it.
AGENTIO_0G_LOG_SYNC_TIMEOUT_MS=30000

# Optional timeout for each KV endpoint probe if the client falls back to discovery.
AGENTIO_0G_KV_RPC_DISCOVERY_TIMEOUT_MS=3000

# Optional timeout for read-after-write visibility on the KV node.
AGENTIO_0G_KV_READ_RETRY_TIMEOUT_MS=15000

# Optional key used by npm run og:kv:status -- to probe a known AgentIO object.
AGENTIO_0G_KV_PROBE_KEY=

# Live network writes are opt-in. The test:og:live script sets this automatically.
AGENTIO_0G_RUN_LIVE=0

# Optional for live AXL examples. Must point to a compiled Gensyn AXL node binary.
AGENTIO_AXL_NODE_BINARY=

# Optional replica target for 0G KV writes. Defaults to 2.
AGENTIO_0G_EXPECTED_REPLICA=2

# 0G Compute Router reasoning example.
# Create this in the 0G portal with inference permission. Keep it server-side.
AGENTIO_0G_COMPUTE_API_KEY=
AGENTIO_0G_COMPUTE_BASE_URL=https://router-api-testnet.integratenetwork.work/v1
AGENTIO_0G_COMPUTE_MODEL=qwen/qwen-2.5-7b-instruct
# 0G's current GLM example model rejects OpenAI JSON object mode, so the example defaults to prompt-only.
# Set to openai-json-object only when the selected model/provider supports response_format=json_object.
AGENTIO_0G_COMPUTE_RESPONSE_FORMAT=prompt-only

# Uniswap live API examples.
# Create a key at https://developers.uniswap.org/dashboard.
# Required for npm run example:uniswap:quote-live when any live API flag is enabled.
AGENTIO_UNISWAP_API_KEY=your_uniswap_api_key

# Optional API base URL. Keep the default unless Uniswap changes the gateway or
# you intentionally point the example at a mock/proxy.
AGENTIO_UNISWAP_API_BASE_URL=https://trade-api.gateway.uniswap.org/v1

# Optional Universal Router header. Uniswap currently accepts only 2.0 or 2.1.1.
# Leave unset to use 2.0.
AGENTIO_UNISWAP_UNIVERSAL_ROUTER_VERSION=2.0

# Optional UniswapX native ETH support flag. Set to 1 only when testing routes
# that use native ETH input and require ERC20-ETH support.
AGENTIO_UNISWAP_ERC20_ETH_ENABLED=0

# Optional Permit2 toggle. Default 0 means use Permit2. Set to 1 only if you
# intentionally want the API to avoid Permit2 where supported.
AGENTIO_UNISWAP_PERMIT2_DISABLED=0

# Optional reply timeout for local Alice/Bob message round-trips in the example.
AGENTIO_UNISWAP_REPLY_TIMEOUT_MS=15000

# Safe live mode. Enables real /check_approval and /quote calls only.
# The script still does not submit /swap or /order by default.
AGENTIO_UNISWAP_RUN_LIVE_API=1

# Legacy alias for live /quote mode. Prefer AGENTIO_UNISWAP_RUN_LIVE_API.
AGENTIO_UNISWAP_RUN_LIVE_QUOTE=0

# Higher-risk live mode. Enables POST /swap preparation after quote. This still
# does not broadcast a transaction, but it may require a Permit2 signature if the
# quote response includes permitData.
AGENTIO_UNISWAP_RUN_LIVE_SWAP=0
AGENTIO_UNISWAP_PERMIT_SIGNATURE=

# Highest-risk live mode. Enables POST /order for UniswapX routes. A signed
# UniswapX order can become fillable once accepted, so leave this disabled until
# the signature flow is deliberate.
AGENTIO_UNISWAP_RUN_LIVE_ORDER=0
AGENTIO_UNISWAP_ORDER_SIGNATURE=
