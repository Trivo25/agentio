{
  "name": "agentio",
  "private": true,
  "type": "module",
  "workspaces": [
    "packages/*",
    "examples/*"
  ],
  "scripts": {
    "build": "tsc -b",
    "typecheck": "tsc -b --pretty false",
    "test": "npm run build && node --test packages/*/dist/*.test.js",
    "example:basic": "node examples/basic/dist/index.js",
    "example:flow": "node examples/basic/dist/sdk-flow.js",
    "example:peer": "node examples/basic/dist/peer-message.js",
    "example:delegation": "node examples/basic/dist/delegation-gate.js",
    "example:noir": "node examples/basic/dist/noir-flow.js",
    "example:og": "node examples/basic/dist/og-storage-flow.js",
    "example:axl": "node examples/basic/dist/axl-message.js",
    "example:local-stack": "node examples/basic/dist/multi-agent-local-stack.js",
    "noir:check": "cd packages/noir/circuits/authorization && nargo check",
    "noir:test": "cd packages/noir/circuits/authorization && nargo test",
    "noir:compile": "cd packages/noir/circuits/authorization && nargo compile",
    "noir:fixture": "npm run build && node packages/noir/dist/fixture.js",
    "noir:execute": "npm run noir:fixture && cd packages/noir/circuits/authorization && nargo execute"
  },
  "devDependencies": {
    "@types/node": "^25.6.0",
    "typescript": "^5.9.3"
  }
}
